generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String         @id @default(cuid())
  name                 String?
  email                String         @unique
  phone                String?
  age                  String?
  gender               String?
  address              String?
  password             String?
  role                 Role           @default(CLIENT)
  isTemporaryPassword  Boolean        @default(false)
  createdAt            DateTime       @default(now())
  emailVerified        DateTime?
  verificationToken    String?        @unique
  resetPasswordToken   String?        @unique
  resetPasswordExpires DateTime?
  bookings             Booking[]
  doctor               Doctor?
  memberships          Membership[]
  surveyProfile        SurveyProfile?
  dateOfBirth          DateTime?
  isActive             Boolean        @default(true)
  orders               Order[]
  notifications        Notification[]
  accounts             Account[]
  image                String?
  blogPosts            BlogPost[]

  @@index([role])
  @@index([createdAt(sort: Desc)])
  @@index([isActive])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model SurveyProfile {
  id                         String   @id @default(cuid())
  userId                     String   @unique
  user                       User     @relation(fields: [userId], references: [id])
  name                       String?
  age                        String?
  phone                      String?
  email                      String?
  skinType                   String?
  usesKoreanProducts         Boolean  @default(false)
  facingSkinIssues           Boolean  @default(false)
  skinIssues                 String[]
  skinIssueDuration          String?
  currentProducts            String[]
  allergicIngredients        String[]
  doubleCleansePreference    String?
  sleepHours                 String?
  waterIntake                String?
  appliesSunscreen           Boolean  @default(false)
  regularPeriodCycle         Boolean  @default(false)
  usedSteroidBasedNightCream Boolean  @default(false)
  skinImages                 String[]
  note                       String?
  updatedAt                  DateTime @updatedAt
  createdAt                  DateTime @default(now())
  currentProductsImage       String?   // optional photo of current products
  previousConsultation       Boolean?  // null = not answered, true = yes, false = no

  @@index([userId])
}

model Membership {
  id           String             @id @default(cuid())
  membershipId String             @unique
  userId       String
  user         User               @relation(fields: [userId], references: [id])
  tier         MembershipTier
  status       MembershipStatus   @default(PENDING)
  payment      MembershipPayment?
  createdAt    DateTime           @default(now())
  expiresAt    DateTime?

  @@index([userId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([expiresAt])
  @@index([tier])
}

model MembershipPayment {
  id                 String        @id @default(cuid())
  membershipId       String        @unique
  membership         Membership    @relation(fields: [membershipId], references: [id])
  paymentMethod      PaymentMethod @default(STRIPE)
  stripePaymentId    String?       @unique
  bkashPaymentId     String?       @unique
  bkashTrxId         String?
  bankTransactionRef String?
  bankTransferProof  String?
  amount             Float
  status             PaymentStatus @default(UNPAID)
  epsTransactionId   String?
  epsMerchantTxnId   String? @unique
  epsPaymentMethod   String?
  epsStatus          String?
  createdAt          DateTime      @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([status])
}

model Service {
  id            String    @id @default(cuid())
  name          String
  description   String?
  details       String?
  price         Float
  originalPrice Float?
  bookings      Booking[]
}

model Doctor {
  id             String               @id @default(cuid())
  name           String
  designation    String
  bio            String?
  availability   String
  image          String?
  specialization DoctorSpecialization @default(AESTHETICIAN)
  slotDuration   Int                  @default(15)
  userId         String?              @unique
  user           User?                @relation(fields: [userId], references: [id])
  bookings       Booking[]
  isActive       Boolean              @default(true)
}

model Booking {
  id               String            @id @default(cuid())
  token            String            @unique
  userId           String
  user             User              @relation(fields: [userId], references: [id])
  serviceId        String?
  service          Service?          @relation(fields: [serviceId], references: [id])
  doctorId         String?
  doctor           Doctor?           @relation(fields: [doctorId], references: [id])
  status           BookingStatus     @default(PENDING)
  appointmentTime  DateTime?
  createdAt        DateTime          @default(now())
  payment          Payment?
  surveyResponse   SurveyResponse?
  diagnosis        Diagnosis?
  routineGuideline RoutineGuideline?
  customerFeedback CustomerFeedback?

  @@index([userId])
  @@index([doctorId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([appointmentTime(sort: Desc)])
}

model Payment {
  id              String        @id @default(cuid())
  booking         Booking       @relation(fields: [bookingId], references: [id])
  bookingId       String        @unique
  stripePaymentId String        @unique
  amount          Float
  status          PaymentStatus @default(UNPAID)
  createdAt       DateTime      @default(now())
}

model SurveyResponse {
  id                         String   @id @default(cuid())
  booking                    Booking? @relation(fields: [bookingId], references: [id])
  bookingId                  String?  @unique
  name                       String
  age                        String
  phone                      String
  email                      String
  skinType                   String
  codeId                     String?
  usesKoreanProducts         Boolean
  facingSkinIssues           Boolean
  skinIssues                 String[]
  skinIssueDuration          String?
  currentProducts            String[]
  allergicIngredients        String[]
  doubleCleansePreference    String
  sleepHours                 String
  waterIntake                String
  appliesSunscreen           Boolean
  regularPeriodCycle         Boolean
  usedSteroidBasedNightCream Boolean
  note                       String?
  skinImages                 String[]
  currentProductsImage       String?
  previousConsultation       Boolean?
  createdAt                  DateTime @default(now())
}

model Product {
  id              String                  @id @default(cuid())
  name            String
  type            String
  price           Float
  skinType        String?
  stockStatus     StockStatus             @default(AVAILABLE)
  stockNote       String?
  description     String?
  image           String?
  isVisible       Boolean                 @default(true)
  recommendations ProductRecommendation[]
  orderItems      OrderItem[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([name])
  @@index([type])
  @@index([stockStatus])
}

model Order {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  status         OrderStatus   @default(PENDING)
  paymentMethod  PaymentMethod @default(BKASH)
  totalAmount    Float
  transactionRef String?
  proofImageUrl  String?
  note           String?
  items          OrderItem[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deliveryArea      DeliveryArea @default(INSIDE_DHAKA)
  deliveryCharge    Float        @default(80)
  deliveryAddress   String?
  estimatedDelivery String?
  epsTransactionId  String?
  epsMerchantTxnId  String? @unique
  epsPaymentMethod  String?

  @@index([createdAt(sort: Desc)])
  @@index([status])
  @@index([userId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)
  price     Float
}

model Diagnosis {
  id                    String                  @id @default(cuid())
  bookingId             String                  @unique
  booking               Booking                 @relation(fields: [bookingId], references: [id])
  problemIdentification String?
  recommendations       ProductRecommendation[]
  updatedAt             DateTime                @updatedAt
  createdAt             DateTime                @default(now())

  @@index([bookingId])
}

model ProductRecommendation {
  id          String    @id @default(cuid())
  diagnosisId String
  diagnosis   Diagnosis @relation(fields: [diagnosisId], references: [id])
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  note        String?
  createdAt   DateTime  @default(now())
}

model RoutineGuideline {
  id        String   @id @default(cuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id])
  content   String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model CustomerFeedback {
  id        String   @id @default(cuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id])
  feedback  String?
  images    String[]
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model LeadCapture {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  interest  String?
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   @default("INFO")
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([userId, isRead])
  @@index([createdAt(sort: Desc)])
}

model BlogPost {
  id          String         @id @default(cuid())
  title       String
  slug        String         @unique
  excerpt     String?
  content     String         @db.Text
  coverImage  String?
  category    String?
  tags        String[]
  status      BlogPostStatus @default(DRAFT)
  authorId    String
  author      User           @relation(fields: [authorId], references: [id])
  publishedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  views       Int            @default(0)

  @@index([slug])
  @@index([status])
  @@index([authorId])
  @@index([publishedAt(sort: Desc)])
}

enum Role {
  CLIENT
  DOCTOR
  CRM
  ADMIN
}

enum DoctorSpecialization {
  AESTHETICIAN
  NUTRITIONIST
  PSYCHIATRIST
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum MembershipTier {
  SIGNATURE
  CRYSTAL
  PLATINUM
}

enum MembershipStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PaymentMethod {
  STRIPE
  BKASH
  BANK_TRANSFER
  CASH
}

enum StockStatus {
  AVAILABLE
  LIMITED
  OUT_OF_STOCK
}

enum OrderStatus {
  PENDING
  VERIFIED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum DeliveryArea {
  INSIDE_DHAKA
  SUB_DHAKA
  OUTSIDE_DHAKA
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}
