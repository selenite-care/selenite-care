generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String         @id @default(cuid())
  name                String?
  email               String         @unique
  phone               String?
  password            String?
  role                Role           @default(CLIENT)
  isTemporaryPassword Boolean        @default(false)
  createdAt           DateTime       @default(now())
  emailVerified       DateTime?
  verificationToken   String?        @unique
  bookings            Booking[]
  doctor              Doctor?
  memberships         Membership[]
  surveyProfile       SurveyProfile?
}

model SurveyProfile {
  id                         String   @id @default(cuid())
  userId                     String   @unique
  user                       User     @relation(fields: [userId], references: [id])
  name                       String?
  age                        String?
  phone                      String?
  email                      String?
  skinType                   String?
  usesKoreanProducts         Boolean  @default(false)
  facingSkinIssues           Boolean  @default(false)
  skinIssues                 String[]
  skinIssueDuration          String?
  currentProducts            String[]
  allergicIngredients        String[]
  doubleCleansePreference    String?
  sleepHours                 String?
  waterIntake                String?
  appliesSunscreen           Boolean  @default(false)
  regularPeriodCycle         Boolean  @default(false)
  usedSteroidBasedNightCream Boolean  @default(false)
  skinImages                 String[]
  note                       String?
  updatedAt                  DateTime @updatedAt
  createdAt                  DateTime @default(now())
  @@index([userId])
}

model Membership {
  id           String             @id @default(cuid())
  membershipId String             @unique
  userId       String
  user         User               @relation(fields: [userId], references: [id])
  tier         MembershipTier
  status       MembershipStatus   @default(PENDING)
  payment      MembershipPayment?
  createdAt    DateTime           @default(now())
  expiresAt    DateTime?
  @@index([userId])
  @@index([status])
}

model MembershipPayment {
  id              String        @id @default(cuid())
  membershipId    String        @unique
  membership      Membership    @relation(fields: [membershipId], references: [id])
  stripePaymentId String        @unique
  amount          Float
  status          PaymentStatus @default(UNPAID)
  createdAt       DateTime      @default(now())
}

model Service {
  id            String    @id @default(cuid())
  name          String
  description   String?
  details       String?
  price         Float
  originalPrice Float?
  bookings      Booking[]
}

model Doctor {
  id           String    @id @default(cuid())
  name         String
  designation  String
  bio          String?
  availability String
  image        String?
  slotDuration Int       @default(15)
  userId       String?   @unique
  user         User?     @relation(fields: [userId], references: [id])
  bookings     Booking[]
}

model Booking {
  id              String          @id @default(cuid())
  token           String          @unique
  userId          String
  user            User            @relation(fields: [userId], references: [id])
  serviceId       String?
  service         Service?        @relation(fields: [serviceId], references: [id])
  doctorId        String?
  doctor          Doctor?         @relation(fields: [doctorId], references: [id])
  status          BookingStatus   @default(PENDING)
  appointmentTime DateTime?
  createdAt       DateTime        @default(now())
  payment         Payment?
  surveyResponse  SurveyResponse?
  diagnosis       Diagnosis?
  routineGuideline RoutineGuideline?
  customerFeedback CustomerFeedback?
  @@index([userId])
  @@index([doctorId])
  @@index([status])
}

model Payment {
  id              String        @id @default(cuid())
  booking         Booking       @relation(fields: [bookingId], references: [id])
  bookingId       String        @unique
  stripePaymentId String        @unique
  amount          Float
  status          PaymentStatus @default(UNPAID)
  createdAt       DateTime      @default(now())
}

model SurveyResponse {
  id                         String    @id @default(cuid())
  booking                    Booking?  @relation(fields: [bookingId], references: [id])
  bookingId                  String?   @unique
  name                       String
  age                        String
  phone                      String
  email                      String
  skinType                   String
  codeId                     String?
  usesKoreanProducts         Boolean
  facingSkinIssues           Boolean
  skinIssues                 String[]
  skinIssueDuration          String?
  currentProducts            String[]
  allergicIngredients        String[]
  doubleCleansePreference    String
  sleepHours                 String
  waterIntake                String
  appliesSunscreen           Boolean
  regularPeriodCycle         Boolean
  usedSteroidBasedNightCream Boolean
  note                       String?
  skinImages                 String[]
  createdAt                  DateTime  @default(now())
}

model Product {
  id              String                  @id @default(cuid())
  name            String
  type            String
  price           Float
  skinType        String?
  recommendations ProductRecommendation[]
  createdAt       DateTime                @default(now())
  @@index([name])
  @@index([type])
}

model Diagnosis {
  id                    String                  @id @default(cuid())
  bookingId             String                  @unique
  booking               Booking                 @relation(fields: [bookingId], references: [id])
  problemIdentification String?
  recommendations       ProductRecommendation[]
  updatedAt             DateTime                @updatedAt
  createdAt             DateTime                @default(now())
  @@index([bookingId])
}

model ProductRecommendation {
  id          String    @id @default(cuid())
  diagnosisId String
  diagnosis   Diagnosis @relation(fields: [diagnosisId], references: [id])
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  note        String?
  createdAt   DateTime  @default(now())
}

model RoutineGuideline {
  id        String   @id @default(cuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id])
  content   String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model CustomerFeedback {
  id        String   @id @default(cuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id])
  feedback  String?
  images    String[]
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

enum Role {
  CLIENT
  DOCTOR
  CRM
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum MembershipTier {
  SIGNATURE
  CRYSTAL
  PLATINUM
}

enum MembershipStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}
