generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  name      String?
  email     String    @unique
  phone     String?
  password  String?
  isTemporaryPassword Boolean @default(false)
  role      Role      @default(CLIENT)
  createdAt DateTime  @default(now())
  bookings  Booking[]
  doctor    Doctor?   // reverse relation
}

model Service {
  id          String    @id @default(cuid())
  name        String
  description String?
  duration    Int
  price       Float
  doctors     Doctor[]
  bookings    Booking[]
}

model Doctor {
  id            String    @id @default(cuid())
  name          String
  designation   String
  bio           String?
  availability  String
  image         String?
  slotDuration  Int       @default(15)
  serviceId     String
  service       Service   @relation(fields: [serviceId], references: [id])
  userId        String?   @unique
  user          User?     @relation(fields: [userId], references: [id])
  bookings      Booking[]
}

model Booking {
  id              String          @id @default(cuid())
  token           String          @unique
  user            User            @relation(fields: [userId], references: [id])
  userId          String
  service         Service         @relation(fields: [serviceId], references: [id])
  serviceId       String
  doctor          Doctor?         @relation(fields: [doctorId], references: [id])
  doctorId        String?
  appointmentTime DateTime
  status          BookingStatus   @default(PENDING)
  payment         Payment?
  surveyResponse  SurveyResponse?
  createdAt       DateTime        @default(now())
}

model Payment {
  id              String        @id @default(cuid())
  booking         Booking       @relation(fields: [bookingId], references: [id])
  bookingId       String        @unique
  stripePaymentId String        @unique
  amount          Float
  status          PaymentStatus @default(UNPAID)
  createdAt       DateTime      @default(now())
}

model SurveyResponse {
  id                      String    @id @default(cuid())
  booking                 Booking?  @relation(fields: [bookingId], references: [id])
  bookingId               String?   @unique
  name                    String
  age                     String
  phone                   String
  email                   String
  skinType                String
  codeId                  String?
  usesKoreanProducts      Boolean
  facingSkinIssues        Boolean
  skinIssues              String[]
  skinIssueDuration       String?
  currentProducts         String[]
  allergicIngredients     String[]
  doubleCleansePreference String
  sleepHours              String
  waterIntake             String      // changed from String[] to String
  appliesSunscreen        Boolean
  regularPeriodCycle      Boolean
  usedSteroidBasedNightCream   Boolean
  note                    String?
  skinImages              String[]  // stores Cloudinary URLs, only for online consultation
  createdAt               DateTime  @default(now())
}

enum Role {
  CLIENT
  DOCTOR
  CRM
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}
